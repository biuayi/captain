# captain 配置（复制为 .env 后按需修改；docker-compose 已内置默认值）

# HTTP
CAPTAIN_HTTP_ADDR=:8080
CAPTAIN_PUBLIC_BASE_URL=http://localhost:8080

# PostgreSQL
CAPTAIN_PG_DSN=postgres://captain:captain@localhost:5432/captain?sslmode=disable

# Redis
CAPTAIN_REDIS_ADDR=localhost:6379

# NATS (JetStream)
CAPTAIN_NATS_URL=nats://localhost:4222

# 签名密钥（生产必须改为强随机；dev 有默认）
CAPTAIN_TOKEN_SECRET=dev-only-insecure-secret-change-me

# 对象存储：local | aliyun （v1 默认 local，文件落 CAPTAIN_STORAGE_DIR）
CAPTAIN_STORAGE_DRIVER=local
CAPTAIN_STORAGE_DIR=/data

# 种子（首启写入 demo 活动方/超管/活动；生产置 false）
CAPTAIN_SEED=true
